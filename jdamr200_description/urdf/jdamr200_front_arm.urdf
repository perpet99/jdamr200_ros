<?xml version="1.0" ?>
<robot name="jdamr200">
    <link name="base_footprint"/>
    <link name="base_link">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <box size="0.5 0.3 0.15"/>
            </geometry>
            <material name="red">
                <color rgba="1 0 0 1"/>
            </material>
        </visual>
        
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <box size="0.5 0.3 0.15"/>
            </geometry>
        </collision>
        
        <inertial>
            <mass value="3.0"/>
            <origin xyz="0 0 0"/>
            <inertia ixx="0.010" ixy="0.0" ixz="0.0" 
                     iyy="0.010" iyz="0.0" 
                     izz="0.010"/>
        </inertial>
    </link>

    <joint name="base_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
    </joint>


    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel_link" />
        <origin xyz="0 0.175 -0.008" rpy="0 0 0"/>
        <axis xyz="0 1 0" />
    </joint>
    <link name="left_wheel_link">
        <visual>
            <origin rpy="1.570795 0 0" xyz="0 0 0"/>
            <geometry>
                <cylinder length="0.05" radius="0.075"/>
            </geometry>
            <material name="yellow">
                <color rgba="1 1 0 1"/>
            </material>
        </visual>
        <collision>
            <origin rpy="1.570795 0 0" xyz="0 0 0"/>
            <geometry>
                <cylinder length="0.05" radius="0.075"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.0625"/>
            <origin rpy="1.570795 0 0" xyz="0 0 0"/>
            <inertia ixx="0.00009" ixy="0.0" ixz="0.0" iyy="0.00009" iyz="0.0" izz="0.00009"/>
        </inertial>
    </link>

    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel_link" />
        <origin xyz="0 -0.175 -0.008" rpy="0 0 0"/>
        <axis xyz="0 1 0" />
    </joint>
    <link name="right_wheel_link">
        <visual>
            <origin rpy="1.570795 0 0" xyz="0 0 0"/>
            <geometry>
                <cylinder length="0.05" radius="0.075"/>
            </geometry>
            <material name="yellow">
                <color rgba="1 1 0 1"/>
            </material>
        </visual>
        <collision>
            <origin rpy="1.570795 0 0" xyz="0 0 0"/>
            <geometry>
                <cylinder length="0.05" radius="0.075"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.0625"/>
            <origin rpy="1.570795 0 0" xyz="0 0 0"/>
            <inertia ixx="0.00009" ixy="0.0" ixz="0.0" iyy="0.00009" iyz="0.0" izz="0.00009"/>
        </inertial>
    </link>

    <joint name="caster_front_joint" type="fixed">
        <parent link="base_link"/>
        <child link="caster_link_front"/>
        <origin xyz="0.2 -0.0 -0.005" rpy="0 0 0"/>
    </joint>
    <link name="caster_link_front">
        <visual>
            <geometry><sphere radius="0.03"/></geometry>
            <material name="black"><color rgba="0 0 0 1"/></material>
        </visual>
        <collision>
            <geometry><sphere radius="0.03"/></geometry>
        </collision>
        <inertial>
            <mass value="0.03"/>
            <inertia ixx="0.00002" ixy="0.0" ixz="0.0" iyy="0.00002" iyz="0.0" izz="0.00002"/>
        </inertial>
        <gazebo reference="caster_link_front">
            <mu1>0.0</mu1>
            <mu2>0.0</mu2>
        </gazebo>
    </link>
    
    <joint name="caster_rear_joint" type="fixed">
        <parent link="base_link"/>
        <child link="caster_link_rear"/>
        <origin xyz="-0.2 -0.0 -0.005" rpy="0 0 0"/>
    </joint>
    <link name="caster_link_rear">
        <visual>
            <geometry><sphere radius="0.03"/></geometry>
            <material name="black"><color rgba="0 0 0 1"/></material>
        </visual>
        <collision>
            <geometry><sphere radius="0.03"/></geometry>
        </collision>
        <inertial>
            <mass value="0.03"/>
            <inertia ixx="0.00002" ixy="0.0" ixz="0.0" iyy="0.00002" iyz="0.0" izz="0.00002"/>
        </inertial>
        <gazebo reference="caster_link_rear">
            <mu1>0.0</mu1>
            <mu2>0.0</mu2>
        </gazebo>
    </link>

    <joint name="laser_joint" type="fixed">
        <origin xyz="0.3 0 0.15" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="laser_link"/>
    </joint>
    <gazebo reference="laser_joint">
        <disableFixedJointLumping>true</disableFixedJointLumping>
    </gazebo>

    <link name="laser_link">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <cylinder length="0.05" radius="0.025"/>
            </geometry>
            <material name="black">
                <color rgba="1 0 0 1"/>
            </material>
        </visual>
        
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <cylinder length="0.05" radius="0.025"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <origin xyz="0 0 0"/>
            <inertia ixx="0.000006" ixy="0.0" ixz="0.0" iyy="0.000006" iyz="0.0" izz="0.000003"/>
        </inertial>
    </link>

     <gazebo>
        <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
            <left_joint>left_wheel_joint</left_joint>
            <right_joint>right_wheel_joint</right_joint>

            <wheel_separation>0.35</wheel_separation>
            <wheel_radius>0.075</wheel_radius>

            <topic>cmd_vel</topic>
            <odom_topic>odom</odom_topic>
            <tf_topic>/tf</tf_topic>
            <frame_id>odom</frame_id>
            <child_frame_id>base_footprint</child_frame_id>
            <odom_publish_frequency>50</odom_publish_frequency>

            <max_wheel_torque>20</max_wheel_torque>
            <max_wheel_acceleration>1.0</max_wheel_acceleration>
        </plugin>
    </gazebo>
    <gazebo reference="laser_link">
        <sensor type="gpu_lidar" name="laser_sensor">
            <pose>0 0 0 0 0 0</pose>
            <visualize>true</visualize>
            <update_rate>10</update_rate>
            <always_on>true</always_on>
            <topic>scan</topic>
            <lidar>
                <scan>
                    <horizontal>
                        <samples>360</samples>
                        <resolution>1</resolution>
                        <min_angle>-3.141592</min_angle>
                        <max_angle>3.141592</max_angle>
                    </horizontal>
                </scan>
                <range>
                    <min>0.05</min>
                    <max>8.0</max>
                    <resolution>0.01</resolution>
                </range>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.01</stddev>
                </noise>
            </lidar>
        </sensor>
    </gazebo>

    <gazebo>
        <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
            <topic>joint_states</topic>
            <joint_name>left_wheel_joint</joint_name>
            <joint_name>right_wheel_joint</joint_name>
        </plugin>
    </gazebo>

    <gazebo reference="base_link">
        <sensor type="imu" name="imu_sensor">
            <always_on>true</always_on>
            <update_rate>100.0</update_rate>
            <topic>imu/data</topic>
            <imu>
                <angular_velocity>
                    <x><noise type="gaussian"><mean>0.0</mean><stddev>0.005</stddev></noise></x>
                    <y><noise type="gaussian"><mean>0.0</mean><stddev>0.005</stddev></noise></y>
                    <z><noise type="gaussian"><mean>0.0</mean><stddev>0.005</stddev></noise></z>
                </angular_velocity>
                <linear_acceleration>
                    <x><noise type="gaussian"><mean>0.0</mean><stddev>0.005</stddev></noise></x>
                    <y><noise type="gaussian"><mean>0.0</mean><stddev>0.005</stddev></noise></y>
                    <z><noise type="gaussian"><mean>0.0</mean><stddev>0.005</stddev></noise></z>
                </linear_acceleration>
            </imu>
        </sensor>
    </gazebo>

    <gazebo reference="base_link">
        <material>Gazebo/Red</material>
    </gazebo>

    <!-- ================================================================ -->
    <!-- SO-101 (SO-ARM100) manipulator, mounted on top of base_link       -->
    <!-- Source: https://github.com/TheRobotStudio/SO-ARM100/tree/main/Simulation/SO101 -->
    <!-- 링크/조인트 이름은 jdamr200과의 충돌을 피하기 위해 so101_ 접두사를 붙임 -->
    <!-- ================================================================ -->

    <material name="so101_3d_printed">
        <color rgba="1.0 0.82 0.12 1.0"/>
    </material>
    <material name="so101_sts3215">
        <color rgba="0.1 0.1 0.1 1.0"/>
    </material>

    <joint name="so101_mount_joint" type="fixed">
        <parent link="base_link"/>
        <child link="so101_base_link"/>
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
    </joint>

    <!-- Link base -->
    <link name="so101_base_link">
        <inertial>
            <origin xyz="0.0137179 -5.19711e-05 0.0334843" rpy="0 0 0"/>
            <mass value="0.147"/>
            <inertia ixx="0.000114686" ixy="-4.59787e-07" ixz="4.97151e-06" iyy="0.000136117" iyz="9.75275e-08" izz="0.000130364"/>
        </inertial>
        <visual>
            <origin xyz="-0.00636471 -9.94414e-05 -0.0024" rpy="1.5708 -1.67685e-15 1.5708"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/base_motor_holder_so101_v1.stl"/>
            </geometry>
            <material name="so101_3d_printed"/>
        </visual>
        <collision>
            <origin xyz="-0.00636471 -9.94414e-05 -0.0024" rpy="1.5708 -1.67685e-15 1.5708"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/base_motor_holder_so101_v1.stl"/>
            </geometry>
        </collision>
        <visual>
            <origin xyz="-0.00636471 -8.97657e-09 -0.0024" rpy="1.5708 -2.78073e-29 1.5708"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/base_so101_v2.stl"/>
            </geometry>
            <material name="so101_3d_printed"/>
        </visual>
        <collision>
            <origin xyz="-0.00636471 -8.97657e-09 -0.0024" rpy="1.5708 -2.78073e-29 1.5708"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/base_so101_v2.stl"/>
            </geometry>
        </collision>
        <visual>
            <origin xyz="0.0263353 -8.97657e-09 0.0437" rpy="-8.21148e-16 7.84513e-18 1.249e-15"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/sts3215_03a_v1.stl"/>
            </geometry>
            <material name="so101_sts3215"/>
        </visual>
        <collision>
            <origin xyz="0.0263353 -8.97657e-09 0.0437" rpy="-8.21148e-16 7.84513e-18 1.249e-15"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/sts3215_03a_v1.stl"/>
            </geometry>
        </collision>
        <visual>
            <origin xyz="-0.0309827 -0.000199441 0.0474" rpy="1.5708 -1.35493e-14 1.5708"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/waveshare_mounting_plate_so101_v2.stl"/>
            </geometry>
            <material name="so101_3d_printed"/>
        </visual>
        <collision>
            <origin xyz="-0.0309827 -0.000199441 0.0474" rpy="1.5708 -1.35493e-14 1.5708"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/waveshare_mounting_plate_so101_v2.stl"/>
            </geometry>
        </collision>
    </link>

    <!-- Link shoulder -->
    <link name="so101_shoulder_link">
        <inertial>
            <origin xyz="-0.0307604 -1.66727e-05 -0.0252713" rpy="0 0 0"/>
            <mass value="0.100006"/>
            <inertia ixx="8.3759e-05" ixy="7.55525e-08" ixz="-1.16342e-06" iyy="8.10403e-05" iyz="1.54663e-07" izz="2.39783e-05"/>
        </inertial>
        <visual>
            <origin xyz="-0.0303992 0.000422241 -0.0417" rpy="1.5708 1.5708 0"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/sts3215_03a_v1.stl"/>
            </geometry>
            <material name="so101_sts3215"/>
        </visual>
        <collision>
            <origin xyz="-0.0303992 0.000422241 -0.0417" rpy="1.5708 1.5708 0"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/sts3215_03a_v1.stl"/>
            </geometry>
        </collision>
        <visual>
            <origin xyz="-0.0675992 -0.000177759 0.0158499" rpy="1.5708 -1.5708 0"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/motor_holder_so101_base_v1.stl"/>
            </geometry>
            <material name="so101_3d_printed"/>
        </visual>
        <collision>
            <origin xyz="-0.0675992 -0.000177759 0.0158499" rpy="1.5708 -1.5708 0"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/motor_holder_so101_base_v1.stl"/>
            </geometry>
        </collision>
        <visual>
            <origin xyz="0.0122008 2.22413e-05 0.0464" rpy="-1.5708 2.35221e-33 0"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/rotation_pitch_so101_v1.stl"/>
            </geometry>
            <material name="so101_3d_printed"/>
        </visual>
        <collision>
            <origin xyz="0.0122008 2.22413e-05 0.0464" rpy="-1.5708 2.35221e-33 0"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/rotation_pitch_so101_v1.stl"/>
            </geometry>
        </collision>
    </link>

    <!-- Link upper_arm -->
    <link name="so101_upper_arm_link">
        <inertial>
            <origin xyz="-0.0898471 -0.00838224 0.0184089" rpy="0 0 0"/>
            <mass value="0.103"/>
            <inertia ixx="4.08002e-05" ixy="-1.97819e-05" ixz="-4.03016e-08" iyy="0.000147318" iyz="8.97326e-09" izz="0.000142487"/>
        </inertial>
        <visual>
            <origin xyz="-0.11257 -0.0155 0.0187" rpy="-3.14159 -5.27356e-16 -1.5708"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/sts3215_03a_v1.stl"/>
            </geometry>
            <material name="so101_sts3215"/>
        </visual>
        <collision>
            <origin xyz="-0.11257 -0.0155 0.0187" rpy="-3.14159 -5.27356e-16 -1.5708"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/sts3215_03a_v1.stl"/>
            </geometry>
        </collision>
        <visual>
            <origin xyz="-0.065085 0.012 0.0182" rpy="3.14159 -0 -1.30911e-30"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/upper_arm_so101_v1.stl"/>
            </geometry>
            <material name="so101_3d_printed"/>
        </visual>
        <collision>
            <origin xyz="-0.065085 0.012 0.0182" rpy="3.14159 -0 -1.30911e-30"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/upper_arm_so101_v1.stl"/>
            </geometry>
        </collision>
    </link>

    <!-- Link lower_arm -->
    <link name="so101_lower_arm_link">
        <inertial>
            <origin xyz="-0.0980701 0.00324376 0.0182831" rpy="0 0 0"/>
            <mass value="0.104"/>
            <inertia ixx="2.87438e-05" ixy="7.41152e-06" ixz="1.26409e-06" iyy="0.000159844" iyz="-4.90188e-08" izz="0.00014529"/>
        </inertial>
        <visual>
            <origin xyz="-0.0648499 -0.032 0.0182" rpy="3.14159 -0 6.67202e-31"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/under_arm_so101_v1.stl"/>
            </geometry>
            <material name="so101_3d_printed"/>
        </visual>
        <collision>
            <origin xyz="-0.0648499 -0.032 0.0182" rpy="3.14159 -0 6.67202e-31"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/under_arm_so101_v1.stl"/>
            </geometry>
        </collision>
        <visual>
            <origin xyz="-0.0648499 -0.032 0.018" rpy="-3.14159 -2.55351e-15 -1.83387e-30"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/motor_holder_so101_wrist_v1.stl"/>
            </geometry>
            <material name="so101_3d_printed"/>
        </visual>
        <collision>
            <origin xyz="-0.0648499 -0.032 0.018" rpy="-3.14159 -2.55351e-15 -1.83387e-30"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/motor_holder_so101_wrist_v1.stl"/>
            </geometry>
        </collision>
        <visual>
            <origin xyz="-0.1224 0.0052 0.0187" rpy="-3.14159 -7.88861e-31 -3.14159"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/sts3215_03a_v1.stl"/>
            </geometry>
            <material name="so101_sts3215"/>
        </visual>
        <collision>
            <origin xyz="-0.1224 0.0052 0.0187" rpy="-3.14159 -7.88861e-31 -3.14159"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/sts3215_03a_v1.stl"/>
            </geometry>
        </collision>
    </link>

    <!-- Link wrist -->
    <link name="so101_wrist_link">
        <inertial>
            <origin xyz="-0.000103312 -0.0386143 0.0281156" rpy="0 0 0"/>
            <mass value="0.079"/>
            <inertia ixx="3.68263e-05" ixy="1.7893e-08" ixz="-5.28128e-08" iyy="2.5391e-05" iyz="3.6412e-06" izz="2.1e-05"/>
        </inertial>
        <visual>
            <origin xyz="8.32667e-17 -0.0424 0.0306" rpy="1.5708 1.5708 0"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/sts3215_03a_no_horn_v1.stl"/>
            </geometry>
            <material name="so101_sts3215"/>
        </visual>
        <collision>
            <origin xyz="8.32667e-17 -0.0424 0.0306" rpy="1.5708 1.5708 0"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/sts3215_03a_no_horn_v1.stl"/>
            </geometry>
        </collision>
        <visual>
            <origin xyz="0 -0.028 0.0181" rpy="-1.5708 -1.5708 0"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/wrist_roll_pitch_so101_v2.stl"/>
            </geometry>
            <material name="so101_3d_printed"/>
        </visual>
        <collision>
            <origin xyz="0 -0.028 0.0181" rpy="-1.5708 -1.5708 0"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/wrist_roll_pitch_so101_v2.stl"/>
            </geometry>
        </collision>
    </link>

    <!-- Link gripper -->
    <link name="so101_gripper_link">
        <inertial>
            <origin xyz="0.000213627 0.000245138 -0.025187" rpy="0 0 0"/>
            <mass value="0.087"/>
            <inertia ixx="2.75087e-05" ixy="-3.35241e-07" ixz="-5.7352e-06" iyy="4.33657e-05" iyz="-5.17847e-08" izz="3.45059e-05"/>
        </inertial>
        <visual>
            <origin xyz="0.0077 0.0001 -0.0234" rpy="-1.5708 -5.19179e-17 -1.66533e-16"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/sts3215_03a_v1.stl"/>
            </geometry>
            <material name="so101_sts3215"/>
        </visual>
        <collision>
            <origin xyz="0.0077 0.0001 -0.0234" rpy="-1.5708 -5.19179e-17 -1.66533e-16"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/sts3215_03a_v1.stl"/>
            </geometry>
        </collision>
        <visual>
            <origin xyz="8.32667e-17 -0.000218214 0.000949706" rpy="-3.14159 -5.55112e-17 0"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/wrist_roll_follower_so101_v1.stl"/>
            </geometry>
            <material name="so101_3d_printed"/>
        </visual>
        <collision>
            <origin xyz="8.32667e-17 -0.000218214 0.000949706" rpy="-3.14159 -5.55112e-17 0"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/wrist_roll_follower_so101_v1.stl"/>
            </geometry>
        </collision>
    </link>

    <!-- Gripper frame (dummy link + fixed joint, TCP reference) -->
    <link name="so101_gripper_frame_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1e-9"/>
            <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
        </inertial>
    </link>

    <joint name="so101_gripper_frame_joint" type="fixed">
        <origin xyz="-0.0079 -0.000218121 -0.0981274" rpy="0 3.14159 0"/>
        <parent link="so101_gripper_link"/>
        <child link="so101_gripper_frame_link"/>
        <axis xyz="0 0 0"/>
    </joint>

    <!-- Link moving_jaw -->
    <link name="so101_moving_jaw_link">
        <inertial>
            <origin xyz="-0.00157495 -0.0300244 0.0192755" rpy="0 0 0"/>
            <mass value="0.012"/>
            <inertia ixx="6.61427e-06" ixy="-3.19807e-07" ixz="-5.90717e-09" iyy="1.89032e-06" iyz="-1.09945e-07" izz="5.28738e-06"/>
        </inertial>
        <visual>
            <origin xyz="-5.55112e-17 -5.55112e-17 0.0189" rpy="9.53145e-17 6.93889e-18 1.24077e-24"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/moving_jaw_so101_v1.stl"/>
            </geometry>
            <material name="so101_3d_printed"/>
        </visual>
        <collision>
            <origin xyz="-5.55112e-17 -5.55112e-17 0.0189" rpy="9.53145e-17 6.93889e-18 1.24077e-24"/>
            <geometry>
                <mesh filename="package://jdamr200_description/meshes/so101/moving_jaw_so101_v1.stl"/>
            </geometry>
        </collision>
    </link>

    <joint name="so101_gripper" type="revolute">
        <origin xyz="0.0202 0.0188 -0.0234" rpy="1.5708 -5.24284e-08 -1.41553e-15"/>
        <parent link="so101_gripper_link"/>
        <child link="so101_moving_jaw_link"/>
        <axis xyz="0 0 1"/>
        <limit effort="10" velocity="10" lower="-0.174533" upper="1.74533"/>
    </joint>

    <joint name="so101_wrist_roll" type="revolute">
        <origin xyz="5.55112e-17 -0.0611 0.0181" rpy="1.5708 0.0486795 3.14159"/>
        <parent link="so101_wrist_link"/>
        <child link="so101_gripper_link"/>
        <axis xyz="0 0 1"/>
        <limit effort="10" velocity="10" lower="-2.74385" upper="2.84121"/>
    </joint>

    <joint name="so101_wrist_flex" type="revolute">
        <origin xyz="-0.1349 0.0052 3.62355e-17" rpy="4.02456e-15 8.67362e-16 -1.5708"/>
        <parent link="so101_lower_arm_link"/>
        <child link="so101_wrist_link"/>
        <axis xyz="0 0 1"/>
        <limit effort="10" velocity="10" lower="-1.65806" upper="1.65806"/>
    </joint>

    <!-- Note: 5-degree calibration offset applied to joint limits (upstream) -->
    <joint name="so101_elbow_flex" type="revolute">
        <origin xyz="-0.11257 -0.028 1.73763e-16" rpy="-3.63608e-16 8.74301e-16 1.5708"/>
        <parent link="so101_upper_arm_link"/>
        <child link="so101_lower_arm_link"/>
        <axis xyz="0 0 1"/>
        <limit effort="10" velocity="10" lower="-1.69" upper="1.69"/>
    </joint>

    <joint name="so101_shoulder_lift" type="revolute">
        <origin xyz="-0.0303992 -0.0182778 -0.0542" rpy="-1.5708 -1.5708 0"/>
        <parent link="so101_shoulder_link"/>
        <child link="so101_upper_arm_link"/>
        <axis xyz="0 0 1"/>
        <limit effort="10" velocity="10" lower="-1.74533" upper="1.74533"/>
    </joint>

    <joint name="so101_shoulder_pan" type="revolute">
        <origin xyz="0.0388353 -8.97657e-09 0.0624" rpy="3.14159 4.18253e-17 -3.14159"/>
        <parent link="so101_base_link"/>
        <child link="so101_shoulder_link"/>
        <axis xyz="0 0 1"/>
        <limit effort="10" velocity="10" lower="-1.91986" upper="1.91986"/>
    </joint>

    <!-- ================================================================ -->
    <!-- ros2_control: SO-101 팔 6개 관절을 gz_ros2_control(GazeboSimSystem)로 제어 -->
    <!-- 바퀴는 기존 gz-sim DiffDrive 플러그인을 그대로 사용하므로 여기 포함하지 않음   -->
    <!-- ================================================================ -->
    <ros2_control name="so101_arm" type="system">
        <hardware>
            <plugin>gz_ros2_control/GazeboSimSystem</plugin>
        </hardware>
        <joint name="so101_shoulder_pan">
            <command_interface name="position">
                <param name="min">-1.91986</param>
                <param name="max">1.91986</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="so101_shoulder_lift">
            <command_interface name="position">
                <param name="min">-1.74533</param>
                <param name="max">1.74533</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="so101_elbow_flex">
            <command_interface name="position">
                <param name="min">-1.69</param>
                <param name="max">1.69</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="so101_wrist_flex">
            <command_interface name="position">
                <param name="min">-1.65806</param>
                <param name="max">1.65806</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="so101_wrist_roll">
            <command_interface name="position">
                <param name="min">-2.74385</param>
                <param name="max">2.84121</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="so101_gripper">
            <command_interface name="position">
                <param name="min">-0.174533</param>
                <param name="max">1.74533</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
    </ros2_control>

    <gazebo>
        <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
            <!-- jdamr200_gazebo.launch.py가 실제 경로로 치환한다 -->
            <parameters>SO101_CONTROLLERS_YAML_PATH</parameters>
        </plugin>
    </gazebo>

</robot>